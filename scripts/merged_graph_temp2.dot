graph G {
  "INVENTORY_TRANS";
  "TRACE";
  "TRACE_INV_TRANS";
  "WAREHOUSE";
  "LOCATION";
  "WORK_ORDER";
  "OPERATION";
  "REQUIREMENT";
  "PAYABLE";
  "PAYABLE_LINE";
  "PAYABLE_DIST";
  "RECEIVER_LINE";
  "CASH_DISBURSE_LINE";
  "CASH_DISBURSE";
  "VENDOR";
  "PURCHASE_ORDER";
  "PURC_ORDER_LINE";
  "INVENTORY_TRANS" -- "WORK_ORDER" ;
  "INVENTORY_TRANS" -- "LOCATION" ;
  "INVENTORY_TRANS" -- "TRACE_INV_TRANS" ;
  "TRACE" -- "TRACE_INV_TRANS" ;
  "WAREHOUSE" -- "LOCATION" ;
  "WORK_ORDER" -- "OPERATION" ;
  "OPERATION" -- "REQUIREMENT" ;
  "PAYABLE" -- "PAYABLE_LINE" [label="VOUCHER_ID"];
  "PAYABLE" -- "PAYABLE_DIST" [label="VOUCHER_ID"];
  "PAYABLE" -- "CASH_DISBURSE_LINE" [label="VOUCHER_ID"];
  "PAYABLE" -- "VENDOR" [label="VENDOR_ID"];
  "PAYABLE_LINE" -- "RECEIVER_LINE" [label="RECEIVER_ID + LINE_NO"];
  "RECEIVER_LINE" -- "PURC_ORDER_LINE" [label="PO_NUMBER + LINE_NO"];
  "CASH_DISBURSE_LINE" -- "CASH_DISBURSE" [label="DISBURSE_ID"];
  "PURCHASE_ORDER" -- "PURC_ORDER_LINE" [label="PO_NUMBER"];
}
