# ArangoDB Connection Configuration
# Copy this file to .env and update with your actual credentials
# NEVER commit .env files with real credentials to git

# ArangoDB Server
DATABASE_HOST=http://127.0.0.1:8529
DATABASE_USERNAME=root
DATABASE_PASSWORD=

# Database Name
DATABASE_NAME=manufacturing_graph

# Optional: Development User (for read-only queries)
# DATABASE_DEV_USER=dev_user
# DATABASE_DEV_PASSWORD=

# Notes:
# - DATABASE_HOST should include http:// or https://
# - Default port is 8529
# - Use read-only credentials for production environments
# - See Documentation/Policies/ENV-Handling.md for security guidelines
