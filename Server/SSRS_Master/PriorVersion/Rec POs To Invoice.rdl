<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DBRMS">
      <DataSourceReference>/Data Sources/dbRMS</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>634452e7-1193-41e7-8712-4b8ca7c24471</rd:DataSourceID>
    </DataSource>
    <DataSource Name="LIVE">
      <DataSourceReference>/Data Sources/Live</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>3bfca57c-3fca-416d-b5b9-684f81715f3a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="Results">
      <Query>
        <DataSourceName>DBRMS</DataSourceName>
        <CommandText>
; WITH CTE_INVOICE AS
(SELECT PO.PNO
	, F.COMPANYID AS VENDOR
	, F.DOCNO AS VENDOR_INVOICE
FROM TBLFILES F
LEFT OUTER JOIN TBLPO PO
	ON F.ID = PO.FILEID
LEFT OUTER JOIN LIVE.DBO.PAYABLE_LINE PL
	ON PL.PURC_ORDER_ID = PO.PNO 
WHERE F.SECTION = 'INVOICE'
	AND PL.VOUCHER_ID IS NULL
	AND F.VOUCHER# IS NULL
	AND DDATE &gt; '1/1/2021'
	AND PO.PNO IN (SELECT PO.PNO
		FROM TBLFILES F
		LEFT OUTER JOIN TBLPO PO
			ON F.ID = PO.FILEID
		LEFT OUTER JOIN LIVE.DBO.PAYABLE_LINE PL
			ON PL.PURC_ORDER_ID = PO.PNO 
		WHERE F.SECTION = 'PACK SLIP'
			AND PL.RECEIVER_ID IS NULL
			AND F.RECEIVER# IS NOT NULL)
)

, CTE_PACKSLIP AS
(SELECT PO.PNO
	, F.COMPANYID AS VENDOR
	, F.DOCNO AS VENDOR_PACKLIST
FROM TBLFILES F
LEFT OUTER JOIN TBLPO PO
	ON F.ID = PO.FILEID
LEFT OUTER JOIN LIVE.DBO.PAYABLE_LINE PL
	ON PL.PURC_ORDER_ID = PO.PNO 
WHERE F.SECTION = 'PACK SLIP'
	AND PL.RECEIVER_ID IS NULL
	AND F.RECEIVER# IS NOT NULL
	AND DDATE &gt; '1/1/2021'
	AND PO.PNO IN (SELECT PO.PNO
		FROM TBLFILES F
		LEFT OUTER JOIN TBLPO PO
			ON F.ID = PO.FILEID
		LEFT OUTER JOIN LIVE.DBO.PAYABLE_LINE PL
			ON PL.PURC_ORDER_ID = PO.PNO 
		WHERE F.SECTION = 'INVOICE'
			AND PL.VOUCHER_ID IS NULL
			AND F.VOUCHER# IS NULL
			AND DDATE &gt; '1/1/2021')
)

SELECT I.*
, P.VENDOR_PACKLIST
,Live.dbo.Get_Inspect(i.pNo) as Inspect
FROM CTE_INVOICE I
INNER JOIN CTE_PACKSLIP P
	ON I.PNO = P.PNO
ORDER BY I.PNO
</CommandText>
      </Query>
      <Fields>
        <Field Name="PNO">
          <DataField>PNO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VENDOR">
          <DataField>VENDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VENDOR_INVOICE">
          <DataField>VENDOR_INVOICE</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VENDOR_PACKLIST">
          <DataField>VENDOR_PACKLIST</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Inspect">
          <DataField>Inspect</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
