  <ReportParameters>
    <ReportParameter Name="ReportNotes">
      <DataType>Boolean</DataType>
      <Prompt>Report Note : Verify Invoice Forms Run Date </Prompt>
    </ReportParameter>
    <ReportParameter Name="StartDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d",-(Day(today)-1), Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>Start Date :</Prompt>
    </ReportParameter>
    <ReportParameter Name="EndDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=Today.AddDays(1-Today.Day).AddMonths(1).AddDays(-1)</Value>
        </Values>
      </DefaultValue>
      <Prompt>End Date :</Prompt>
    </ReportParameter>
    <ReportParameter Name="City">
      <DataType>String</DataType>
      <Prompt>City :</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Helena</Value>
            <Label>Helena</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Other</Value>
            <Label>Other</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Tukwila</Value>
            <Label>Tukwila</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>BOE602</Value>
            <Label>BOE602</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
      <MultiValue>true</MultiValue>
    </ReportParameter>
  </ReportParameters>
