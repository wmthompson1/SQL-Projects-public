  <ReportParameters>
    <ReportParameter Name="ReportNote">
      <DataType>Boolean</DataType>
      <Prompt>Report Note : Verify Invoice Forms Run Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="StartDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd(DateInterval.Day, 2-WeekDay(Today), DateAdd(DateInterval.Day, -7, Today()))</Value>
        </Values>
      </DefaultValue>
      <Prompt>Start Date :</Prompt>
    </ReportParameter>
    <ReportParameter Name="EndDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd(DateInterval.Day, 1-WeekDay(Today), Today())</Value>
        </Values>
      </DefaultValue>
      <Prompt>End Date :</Prompt>
    </ReportParameter>
  </ReportParameters>
